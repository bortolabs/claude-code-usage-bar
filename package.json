{
  "name": "claude-code-usage-bar",
  "displayName": "Claude Code Usage & Status",
  "description": "%extension.description%",
  "version": "0.35.1",
  "publisher": "bortolabs",
  "sponsor": {
    "url": "https://github.com/sponsors/bortolabs"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bortolabs/claude-code-usage-bar.git"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "tokens",
    "usage",
    "status bar"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:claudeUsageView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeUsage",
          "title": "Claude Usage",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "claudeUsage": [
        {
          "id": "claudeUsageView",
          "name": "Uso da sessão",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeUsageBar.refresh",
        "title": "%cmd.refresh.title%"
      },
      {
        "command": "claudeUsageBar.openState",
        "title": "%cmd.openState.title%"
      },
      {
        "command": "claudeUsageBar.openPanel",
        "title": "%cmd.openPanel.title%"
      },
      {
        "command": "claudeUsageBar.openDashboard",
        "title": "%cmd.openDashboard.title%"
      },
      {
        "command": "claudeUsageBar.exportDashboardHtml",
        "title": "%cmd.exportDashboardHtml.title%"
      },
      {
        "command": "claudeUsageBar.exportCsv",
        "title": "%cmd.exportCsv.title%"
      },
      {
        "command": "claudeUsageBar.aiAdvice",
        "title": "%cmd.aiAdvice.title%"
      },
      {
        "command": "claudeUsageBar.setAiAdviceKey",
        "title": "%cmd.setAiAdviceKey.title%"
      },
      {
        "command": "claudeUsageBar.oauthConsent",
        "title": "%cmd.oauthConsent.title%"
      },
      {
        "command": "claudeUsageBar.cycleStyle",
        "title": "%cmd.cycleStyle.title%"
      },
      {
        "command": "claudeUsageBar.setStyle",
        "title": "%cmd.setStyle.title%"
      },
      {
        "command": "claudeUsageBar.toggleAlert",
        "title": "%cmd.toggleAlert.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "claudeUsageBar.stateFilePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.stateFilePath.desc%"
        },
        "claudeUsageBar.accountType": {
          "type": "string",
          "enum": [
            "auto",
            "subscription",
            "api"
          ],
          "enumDescriptions": [
            "%config.accountType.enum.auto%",
            "%config.accountType.enum.subscription%",
            "%config.accountType.enum.api%"
          ],
          "default": "auto",
          "markdownDescription": "%config.accountType.desc%"
        },
        "claudeUsageBar.mode": {
          "type": "string",
          "enum": [
            "auto",
            "subscriber",
            "cost"
          ],
          "enumDescriptions": [
            "%config.mode.enum.auto%",
            "%config.mode.enum.subscriber%",
            "%config.mode.enum.cost%"
          ],
          "default": "auto",
          "markdownDescription": "%config.mode.desc%"
        },
        "claudeUsageBar.costCapUsd": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "markdownDescription": "%config.costCapUsd.desc%"
        },
        "claudeUsageBar.monthlyBudgetUsd": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "%config.monthlyBudgetUsd.desc%"
        },
        "claudeUsageBar.monthlyBudgetAlertEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.monthlyBudgetAlertEnabled.desc%"
        },
        "claudeUsageBar.insightsEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.insightsEnabled.desc%"
        },
        "claudeUsageBar.costWindow": {
          "type": "string",
          "enum": [
            "5h",
            "today",
            "7d",
            "30d"
          ],
          "enumDescriptions": [
            "%config.costWindow.enum.5h%",
            "%config.costWindow.enum.today%",
            "%config.costWindow.enum.7d%",
            "%config.costWindow.enum.30d%"
          ],
          "default": "5h",
          "markdownDescription": "%config.costWindow.desc%"
        },
        "claudeUsageBar.tooltipDetail": {
          "type": "string",
          "enum": [
            "compact",
            "full"
          ],
          "enumDescriptions": [
            "%config.tooltipDetail.enum.compact%",
            "%config.tooltipDetail.enum.full%"
          ],
          "default": "full",
          "markdownDescription": "%config.tooltipDetail.desc%"
        },
        "claudeUsageBar.tipsContextBigPct": {
          "type": "number",
          "default": 25,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%config.tipsContextBigPct.desc%"
        },
        "claudeUsageBar.tipsCacheReadPct": {
          "type": "number",
          "default": 70,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%config.tipsCacheReadPct.desc%"
        },
        "claudeUsageBar.tipsOpusPct": {
          "type": "number",
          "default": 70,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%config.tipsOpusPct.desc%"
        },
        "claudeUsageBar.tipsMcpCalls": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "markdownDescription": "%config.tipsMcpCalls.desc%"
        },
        "claudeUsageBar.tipsSubagentPct": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%config.tipsSubagentPct.desc%"
        },
        "claudeUsageBar.barStyle": {
          "type": "string",
          "enum": [
            "ring",
            "bar",
            "number",
            "icon"
          ],
          "enumDescriptions": [
            "%config.barStyle.enum.ring%",
            "%config.barStyle.enum.bar%",
            "%config.barStyle.enum.number%",
            "%config.barStyle.enum.icon%"
          ],
          "default": "ring",
          "markdownDescription": "%config.barStyle.desc%"
        },
        "claudeUsageBar.statusBarValue": {
          "type": "string",
          "enum": [
            "quota",
            "today",
            "session"
          ],
          "enumDescriptions": [
            "%config.statusBarValue.enum.quota%",
            "%config.statusBarValue.enum.today%",
            "%config.statusBarValue.enum.session%"
          ],
          "default": "quota",
          "markdownDescription": "%config.statusBarValue.desc%"
        },
        "claudeUsageBar.warnThreshold": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.warnThreshold.desc%"
        },
        "claudeUsageBar.errorThreshold": {
          "type": "number",
          "default": 85,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.errorThreshold.desc%"
        },
        "claudeUsageBar.alignment": {
          "type": "string",
          "enum": [
            "right",
            "left"
          ],
          "default": "right",
          "description": "%config.alignment.desc%"
        },
        "claudeUsageBar.priority": {
          "type": "number",
          "default": 100,
          "description": "%config.priority.desc%"
        },
        "claudeUsageBar.staleAfterSeconds": {
          "type": "number",
          "default": 900,
          "description": "%config.staleAfterSeconds.desc%"
        },
        "claudeUsageBar.ccusageCommand": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.ccusageCommand.desc%"
        },
        "claudeUsageBar.ccusageRefreshSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "%config.ccusageRefreshSeconds.desc%"
        },
        "claudeUsageBar.useOAuthUsage": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.useOAuthUsage.desc%"
        },
        "claudeUsageBar.oauthRefreshSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 20,
          "description": "%config.oauthRefreshSeconds.desc%"
        },
        "claudeUsageBar.burnRateAlertEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.burnRateAlertEnabled.desc%"
        },
        "claudeUsageBar.burnRateMaxPerHour": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "markdownDescription": "%config.burnRateMaxPerHour.desc%"
        },
        "claudeUsageBar.alertCooldownMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "description": "%config.alertCooldownMinutes.desc%"
        },
        "claudeUsageBar.colorByProjection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.colorByProjection.desc%"
        },
        "claudeUsageBar.intenseTokensPerMin": {
          "type": "number",
          "default": 50000,
          "minimum": 1000,
          "markdownDescription": "%config.intenseTokensPerMin.desc%"
        },
        "claudeUsageBar.sessionTokenCap": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "%config.sessionTokenCap.desc%"
        },
        "claudeUsageBar.resetWarningMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "markdownDescription": "%config.resetWarningMinutes.desc%"
        },
        "claudeUsageBar.lowQuotaThreshold": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 100,
          "markdownDescription": "%config.lowQuotaThreshold.desc%"
        },
        "claudeUsageBar.ringTheme": {
          "type": "string",
          "enum": [
            "semaforo",
            "claude",
            "mono",
            "custom"
          ],
          "enumDescriptions": [
            "%config.ringTheme.enum.semaforo%",
            "%config.ringTheme.enum.claude%",
            "%config.ringTheme.enum.mono%",
            "%config.ringTheme.enum.custom%"
          ],
          "default": "semaforo",
          "markdownDescription": "%config.ringTheme.desc%"
        },
        "claudeUsageBar.ringColor": {
          "type": "string",
          "default": "#4caf78",
          "markdownDescription": "%config.ringColor.desc%"
        },
        "claudeUsageBar.blockSummaryEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.blockSummaryEnabled.desc%"
        },
        "claudeUsageBar.statusCheckEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.statusCheckEnabled.desc%"
        },
        "claudeUsageBar.statusBadgeEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.statusBadgeEnabled.desc%"
        },
        "claudeUsageBar.statusNotifyEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.statusNotifyEnabled.desc%"
        },
        "claudeUsageBar.statusRefreshSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "%config.statusRefreshSeconds.desc%"
        },
        "claudeUsageBar.exportStateEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.exportStateEnabled.desc%"
        },
        "claudeUsageBar.exportStatePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.exportStatePath.desc%"
        },
        "claudeUsageBar.dashboardWindow": {
          "type": "string",
          "enum": [
            "today",
            "week",
            "month",
            "all"
          ],
          "default": "today",
          "markdownDescription": "%config.dashboardWindow.desc%"
        },
        "claudeUsageBar.aiAdviceApiStyle": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai"
          ],
          "default": "anthropic",
          "markdownDescription": "%config.aiAdviceApiStyle.desc%"
        },
        "claudeUsageBar.aiAdviceEndpoint": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.aiAdviceEndpoint.desc%"
        },
        "claudeUsageBar.aiAdviceModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.aiAdviceModel.desc%"
        },
        "claudeUsageBar.aiAdvicePromptWindowDays": {
          "type": "number",
          "default": 30,
          "markdownDescription": "%config.aiAdvicePromptWindowDays.desc%"
        },
        "claudeUsageBar.aiAdviceMaxPrompts": {
          "type": "number",
          "default": 40,
          "markdownDescription": "%config.aiAdviceMaxPrompts.desc%"
        },
        "claudeUsageBar.historyEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.historyEnabled.desc%"
        },
        "claudeUsageBar.historyRetentionDays": {
          "type": "number",
          "default": 365,
          "minimum": 7,
          "markdownDescription": "%config.historyRetentionDays.desc%"
        },
        "claudeUsageBar.weeklySummaryEnabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.weeklySummaryEnabled.desc%"
        },
        "claudeUsageBar.advisorEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.advisorEnabled.desc%"
        },
        "claudeUsageBar.advisorNotifyEnabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.advisorNotifyEnabled.desc%"
        },
        "claudeUsageBar.advisorCooldownHours": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "markdownDescription": "%config.advisorCooldownHours.desc%"
        },
        "claudeUsageBar.tokenGoalFiveHour": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "%config.tokenGoalFiveHour.desc%"
        },
        "claudeUsageBar.tokenGoalDaily": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "%config.tokenGoalDaily.desc%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && rm -rf out && npm run bundle -- --minify",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "l10n": "./l10n"
}
